{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "prestart": "node ../scripts/generate-mobile-env.mjs",
    "preandroid": "node ../scripts/generate-mobile-env.mjs",
    "start": "expo start",
    "android": "expo run:android",
    "android:dev": "expo start --android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "node ../scripts/generate-mobile-env.mjs && expo export --platform web",
    "build:web": "npm run build",
    "build:apk": "cd .. && npm run build:ems:apk",
    "prebuild:android": "expo prebuild --platform android --clean --non-interactive",
    "build:android:apk": "expo prebuild --platform android --non-interactive && cd android && chmod +x gradlew && ./gradlew assembleRelease",
    "build:android:apk:clean": "expo prebuild --platform android --clean --non-interactive && cd android && chmod +x gradlew && ./gradlew assembleRelease",
    "build:android:debug": "cd android && chmod +x gradlew && ./gradlew assembleDebug",
    "build:android:apk:debug": "expo prebuild --platform android --non-interactive && cd android && chmod +x gradlew && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native/virtualized-lists": "^0.81.5",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@supabase/supabase-js": "^2.105.4",
    "aes-js": "^3.1.2",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "leaflet": "^1.9.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/aes-js": "^3.1.4",
    "@types/leaflet": "^1.9.21",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
