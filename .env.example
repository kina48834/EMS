# =============================================================================
# EMS — one Supabase project for Vite web (src/) + Expo mobile (mobile/)
# Copy to .env at repo root, then copy EXPO_PUBLIC_* lines to mobile/.env
# =============================================================================

# Web (Vite) — used by src/lib/supabase.ts
# Vercel: Project → Settings → Environment Variables (Production + Preview)
#   VITE_SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://YOUR_APP.vercel.app
#   Redirect URLs: https://YOUR_APP.vercel.app/**
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Mobile (Expo) — must match web URL/key (same project)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Server / migrations only (never ship to clients)
SUPABASE_SERVICE_ROLE_KEY=your_secret_key
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# =============================================================================
# Supabase SQL (run in SQL Editor, in order):
#   1. supabase/sql/00_all_in_one.sql
#   2. supabase/sql/12_incident_location_name.sql  (existing DBs only)
#   3. supabase/sql/demo_accounts.sql
# Auth: disable "Confirm email" for demo logins.
# =============================================================================
